#!/usr/bin/env bash

# change to the project root
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$DIR"/.. || exit

microk8s kubectl delete secret env-vars

microk8s kubectl delete -f internal/pascalallen/infrastructure/etc/k8s/go
microk8s kubectl delete -f internal/pascalallen/infrastructure/etc/k8s/rabbitmq
microk8s kubectl delete -f internal/pascalallen/infrastructure/etc/k8s/postgres

microk8s kubectl create secret generic env-vars --from-env-file=.env

microk8s kubectl apply -f internal/pascalallen/infrastructure/etc/k8s/postgres
microk8s kubectl apply -f internal/pascalallen/infrastructure/etc/k8s/rabbitmq
microk8s kubectl apply -f internal/pascalallen/infrastructure/etc/k8s/go
# microk8s kubectl run pascalallen-go --image=pascalallen/pascalallen-go -- --uri amqp://<RABBITMQ_USERNAME>:<RABBITMQ_PASSWORD>@<APP_CLUSTER_IP>
